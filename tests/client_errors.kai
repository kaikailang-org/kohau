# tests/client_errors.kai — error propagation through the cell.
#
# A robust request/reply protocol must carry failures back across
# the mailbox as cleanly as it carries successes. This fixture
# drives the `SqlErr` path of every helper and confirms the error
# message surfaces as `Err(msg)` at the caller — still in
# `Actor[SqlMsg]`, no `Ffi`.
#
# Cases:
#   1. exec of malformed DDL            -> Err (SQLite parse error)
#   2. query_row against a missing table -> Err (no such table)
#   3. query_scalar of malformed SQL    -> Err (SQLite parse error)
#   4. exec of valid DDL after errors   -> Ok (the cell survives a
#                                          failed statement; the
#                                          connection is intact)
#
# The point of case 4: a failed statement must not poison the cell.
# Each operation prepares + finalizes its own statement, so an error
# in one leaves the connection usable for the next. This is the
# liveness property that makes the cell safe to keep open.

import actor
import kohau.sqlite.client

fn show_exec(label: String, r: Result[String, Int]) : Unit / Console =
  match r {
    Ok(changed) -> Stdout.print(label ++ ": ok changes=" ++ int_to_string(changed))
    Err(_)      -> Stdout.print(label ++ ": err")
  }

fn show_scalar(label: String, r: Result[String, Int]) : Unit / Console =
  match r {
    Ok(n)  -> Stdout.print(label ++ ": " ++ int_to_string(n))
    Err(_) -> Stdout.print(label ++ ": err")
  }

fn show_row(label: String, r: Result[String, Option[[String]]]) : Unit / Console =
  match r {
    Ok(_)  -> Stdout.print(label ++ ": ok")
    Err(_) -> Stdout.print(label ++ ": err")
  }

# We print only "err" / "ok" (not the SQLite message text) so the
# golden stays stable across libsqlite3 versions, whose error
# strings differ in wording.
fn body(c: Pid[SqlMsg]) : Unit / Actor[SqlMsg] + Console = {
  # 1. malformed DDL
  show_exec("bad ddl",
    client.exec(c, "CREATE TABL oops (", []))

  # 2. query against a table that does not exist
  show_row("missing table",
    client.query_row(c, "SELECT data FROM ghost WHERE id = ?", [BindText("x")]))

  # 3. malformed scalar query
  show_scalar("bad scalar",
    client.query_scalar(c, "SELECT COUNT( FROM", []))

  # 4. the cell survived: a valid statement now works
  show_exec("recover ddl",
    client.exec(c, "CREATE TABLE ok_table (id TEXT PRIMARY KEY, data TEXT NOT NULL)", []))
  show_scalar("recover count",
    client.query_scalar(c, "SELECT COUNT(*) FROM ok_table", []))

  client.close(c)
}

fn main() : Int / Spawn + Ffi + Console = {
  with_mailbox { client.with_client(":memory:", body) }
  0
}
