# tests/client_tx.kai — transaction scope (`with_tx`) over the
# cell-wrapped client.
#
# `with_tx(c, body)` brackets the body in BEGIN / COMMIT-or-ROLLBACK:
# COMMIT if the body returns `Ok`, ROLLBACK if it returns `Err`. The
# fixture proves all three routes against an in-memory DB, all in
# `Actor[SqlMsg]` — no `Ffi`.
#
# Cases:
#   1. Commit path — body returns Ok; both inserts persist.
#   2. Explicit rollback — body returns Err; the insert it made does
#      NOT persist (count unchanged from before the tx).
#   3. Mid-body failure rollback — body inserts one row, then an
#      inner op fails and the body propagates Err; the partial insert
#      does NOT persist (atomicity: all-or-nothing).
#
# After each tx we print COUNT(*) to show what actually landed.
# Trace is deterministic: `:memory:` is fresh per run.

import actor

import kohau.sqlite.client

fn count(c: Pid[SqlMsg]) : Int / Actor[SqlMsg] = match client.query_scalar(c, "SELECT COUNT(*) FROM t", []) {
  Ok(n) -> n
  Err(_) -> -1
}

fn show_tx(label: String, r: Result[Int, String]) : Unit / Console = match r {
  Ok(n) -> Stdout.print(label ++ (": Ok(" ++ (int_to_string(n) ++ ")")))
  Err(_) -> Stdout.print(label ++ ": Err")
}

fn show_count(label: String, n: Int) : Unit / Console = Stdout.print(label ++ (": count=" ++ int_to_string(n)))

fn body(c: Pid[SqlMsg]) : Unit / Actor[SqlMsg] + Console {
  let _ = client.exec(c, "CREATE TABLE t (id TEXT PRIMARY KEY, data TEXT NOT NULL)", [])
  # ---- 1. commit path ----
  # Body returns Ok(2) — the value of the last insert's change count,
  # threaded out by with_tx. Both rows persist.
  let tx1 = client.with_tx(c, tx => {
    match client.exec(tx, "INSERT INTO t VALUES (?, ?)", [BindText("a"), BindText("1")]) {
      Err(m) -> Err(m)
      Ok(_) -> client.exec(tx, "INSERT INTO t VALUES (?, ?)", [BindText("b"), BindText("2")])
    }
  })
  show_tx("commit tx", tx1)
  show_count("after commit", count(c))
  # ---- 2. explicit rollback ----
  # Body inserts a row but deliberately returns Err — the insert is
  # rolled back, count stays at 2.
  let tx2 = client.with_tx(c, tx => {
    let _ = client.exec(tx, "INSERT INTO t VALUES (?, ?)", [BindText("c"), BindText("3")])
    Err("caller aborts the tx")
  })
  show_tx("rollback tx", tx2)
  show_count("after rollback", count(c))
  # ---- 3. mid-body failure rollback ----
  # First insert succeeds; second is a constraint violation (duplicate
  # primary key 'a' from tx1). The body propagates that Err, so the
  # whole tx rolls back — the good first insert ('d') does NOT persist.
  let tx3 = client.with_tx(c, tx => {
    match client.exec(tx, "INSERT INTO t VALUES (?, ?)", [BindText("d"), BindText("4")]) {
      Err(m) -> Err(m)
      Ok(_) -> client.exec(tx, "INSERT INTO t VALUES (?, ?)", [BindText("a"), BindText("dup")])
    }
  })
  show_tx("mid-fail tx", tx3)
  show_count("after mid-fail", count(c))
  client.close(c)
}

fn main() : Int / Spawn + Ffi + Console {
  with_mailbox(() => {
    client.with_client(":memory:", body)
  })
  0
}
